# base.env — bazowe zmienne środowiskowe
# Wczytywane przez run.sh, GPU-specific vars są ustawiane dynamicznie
#
# ── Wspólne dla wszystkich GPU ───────────────────────────────────────────────
PROTON_LOG=0
DXVK_STATE_CACHE_PATH="$HOME/.cache/dxvk"

# ── AMD / Mesa ───────────────────────────────────────────────────────────────
# Odkomentuj jeśli używasz AMD/Intel (Mesa):
# RADV_PERFTEST=gpl
# mesa_glthread=true
# DXVK_ASYNC=1

# ── NVIDIA ───────────────────────────────────────────────────────────────────
# Odkomentuj jeśli używasz NVIDIA:
# __GL_THREADED_OPTIMIZATIONS=1
# VKD3D_CONFIG=dxr

# ── Laptop Hybrid GPU (PRIME) ─────────────────────────────────────────────────
# Odkomentuj dla NVIDIA PRIME (Intel iGPU + NVIDIA dGPU):
# __NV_PRIME_RENDER_OFFLOAD=1
# __VK_LAYER_NV_optimus=NVIDIA_only
# __GLX_VENDOR_LIBRARY_NAME=nvidia
